# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=whsec_...

# Supabase Postgres (Prisma)
# The Supabase Vercel integration injects these automatically in deployment.
# POSTGRES_PRISMA_URL = pooled (pgbouncer) connection used at runtime.
# POSTGRES_URL_NON_POOLING = direct connection used for migrations / db push.
POSTGRES_PRISMA_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
POSTGRES_URL_NON_POOLING=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# AgentMail (per-user key is stored in the app; this is optional for local dev)
# AGENTMAIL_API_KEY=...


# Tavily web search (enables the agent's discovery + the search_web MCP tool)
# TAVILY_API_KEY=...

# Apify — one token runs the curated Actors in Discover: Google Maps local
# leads, site contact-detail extraction, and Google search.
# APIFY_TOKEN=apify_api_...

# OpenAI — powers the Scalar agent + vector-memory embeddings
# OPENAI_API_KEY=...
# OPENAI_AGENT_MODEL=gpt-4o   # optional override

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Creem.io billing (optional - without these, checkout returns "Billing is not
# configured yet" and the credit meter still runs on plan defaults)
# CREEM_API_KEY=creem_...
# CREEM_WEBHOOK_SECRET=whsec_...
# CREEM_PRODUCT_STARTER=prod_...
# CREEM_PRODUCT_PRO=prod_...
# CREEM_PRODUCT_BUSINESS=prod_...

# x402 agent payments (optional). Lets a connected agent pay in USDC over HTTP
# to top up credits (/api/x402/topup) or buy a plan (/api/x402/subscribe).
# Without X402_PAY_TO these endpoints return 501. X402_PAY_TO is the treasury
# wallet that receives USDC. X402_NETWORK is "base" (mainnet, real USDC, needs
# the CDP_API_KEY_* facilitator credentials) or "base-sepolia" (testnet, public
# facilitator, no real money). Defaults to "base".
# X402_PAY_TO=0xYourTreasuryWalletAddress
# X402_NETWORK=base
# CDP_API_KEY_ID=...
# CDP_API_KEY_SECRET=...

# Upstash Redis — durable rate limiting (cross-instance). Without these the
# limiter falls back to a per-instance in-memory limiter (fine for local dev).
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
