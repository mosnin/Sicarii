// Scalar — Prisma schema (Postgres on Supabase)
// Auth is Clerk; users are mirrored here via the Clerk webhook.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  // Read the Supabase Vercel integration's auto-injected vars directly so no
  // manual env control is needed. POSTGRES_PRISMA_URL = pooled (pgbouncer),
  // POSTGRES_URL_NON_POOLING = direct connection (migrations / db push).
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
  // pgvector powers the agent's token-efficient recall (memory_chunks.embedding).
  extensions = [vector]
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String
  firstName String?
  lastName  String?
  imageUrl  String?
  role      String   @default("member")
  // Operator-authored context the agent reads (what you're selling) + a
  // connected AgentMail key for email. Both are per-user settings.
  productContext  String? @db.Text
  agentMailApiKey String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entities         Entity[]
  contacts         Contact[]
  apiKeys          ApiKey[]
  conversations    Conversation[]
  memoryChunks     MemoryChunk[]
  synthozJobs      SynthozJob[]
  intentMonitors   IntentMonitor[]
  researchSchedules ResearchSchedule[]

  @@map("users")
}

// Correlation record for Synthoz's ASYNC results. Synthoz is one developer
// account (one API key, one set of outgoing webhooks), but many Scalar users
// trigger searches. When a user fires an async Synthoz call we stamp a pending
// job keyed by what was searched (domain / company); when the result POSTs back
// to /api/webhooks/synthoz — carrying no user identity — we match it to the most
// recent pending job for that key and attribute the record to that user.
model SynthozJob {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  action     String // "enrich-company" | "convert-company-names" | "extract-emails-from-urls" | "find-emails-first-last"
  domainKey  String? // normalized domain searched (host only, no scheme/www)
  companyKey String? // normalized company name searched (lowercased)
  status     String    @default("pending") // "pending" | "resolved"
  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([userId])
  @@index([status, domainKey])
  @@index([status, companyKey])
  @@map("synthoz_jobs")
}

// A chat with the Scalar agent. A fresh one is created on each page load; long-term
// continuity comes from vector recall over memory_chunks, not from replaying history.
model Conversation {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

// Token-efficient memory: embedded snippets of past messages and CRM data the agent
// can recall by similarity instead of stuffing everything into the prompt.
model MemoryChunk {
  id        String                       @id @default(uuid())
  userId    String
  user      User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // "message" | "entity" | "contact" | "email"
  refId     String? // id of the source record
  content   String                       @db.Text
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())

  @@index([userId])
  @@map("memory_chunks")
}

// Per-user API key for the MCP server / REST API. We store only a SHA-256 hash;
// the plaintext is shown once at creation. `prefix`/`last4` are for display.
model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  hashedKey  String    @unique
  prefix     String
  last4      String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("api_keys")
}

// A business in the CRM. Discovered (e.g. via Tavily), enriched (via Synthoz by
// domain), and operated on by agents. Has many contacts.
model Entity {
  id        String  @id @default(uuid())
  userId    String // owner (the Scalar account)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  domain      String?
  website     String?
  industry    String?
  location    String?
  description String? @db.Text
  size        String?

  status    EntityStatus @default(NEW)
  source    String? // "agent:tavily", "manual", "agent", etc.
  tags      String[]     @default([])
  notes     String?      @db.Text

  // Enrichment payload (Synthoz-shaped JSON the agent can read/extend).
  enrichment Json?

  contacts  Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@map("entities")
}

enum EntityStatus {
  NEW
  ENRICHED
  ARCHIVED
}

// A person/company in the CRM. Agents discover, enrich, and operate on these.
model Contact {
  id        String  @id @default(uuid())
  userId    String // owner (the Scalar account this contact belongs to)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional parent business. A contact is assigned to an entity or stands solo.
  entityId  String?
  entity    Entity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  // Core
  name      String?
  email     String?
  phone     String?
  company   String?
  title     String?
  website   String?
  linkedin  String?
  location  String?

  // Pipeline
  status    ContactStatus @default(NEW)
  source    String? // how it was found: "discover:domain", "manual", "import", etc.
  tags      String[]      @default([])
  notes     String?

  // Enrichment payload (provider-shaped JSON the agent can read/extend)
  enrichment Json?

  emails    ContactEmail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([entityId])
  @@map("contacts")
}

enum ContactStatus {
  NEW
  ENRICHED
  CONTACTED
  REPLIED
  QUALIFIED
  WON
  LOST
  ARCHIVED
}

// Email exchanged with a contact. Rendered from the connected AgentMail account;
// the agent can save messages here as reusable context.
model ContactEmail {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // AgentMail linkage (nullable until a key is connected)
  agentMailMessageId String?
  agentMailThreadId  String?

  direction Emaildirection
  fromAddr  String?
  toAddr    String?
  subject   String?
  body      String?        @db.Text
  // Whether the agent flagged this message as durable context.
  savedAsContext Boolean   @default(false)

  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([agentMailThreadId])
  @@map("contact_emails")
}

enum Emaildirection {
  INBOUND
  OUTBOUND
}

// Recurring Exa intent monitor — runs on a schedule, delivers results via webhook.
// Results are attributed to userId and saved as entities tagged "intent".
model IntentMonitor {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  query        String    @db.Text
  frequency    String    @default("daily") // "daily" | "weekly"
  exaMonitorId String? // Exa's remote monitor ID (set after createExaMonitor succeeds)
  active       Boolean   @default(true)
  lastRunAt    DateTime?
  nextRunAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([active, nextRunAt])
  @@map("intent_monitors")
}

// Scheduled deep research (Linkup or Exa) on a topic, contact, or entity.
// When targetType+targetId are set, research is merged into that record's notes.
// When null, top sources are saved as new entities.
model ResearchSchedule {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  query      String    @db.Text
  provider   String    @default("linkup") // "linkup" | "exa"
  depth      String    @default("deep")   // "standard" | "deep"
  frequency  String    @default("daily")  // "hourly" | "daily" | "weekly"
  targetType String? // "contact" | "entity" | null (saves as new records)
  targetId   String?
  active     Boolean   @default(true)
  lastRunAt  DateTime?
  nextRunAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([active, nextRunAt])
  @@map("research_schedules")
}
