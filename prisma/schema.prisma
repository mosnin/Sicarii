// Scalar — Prisma schema (Postgres on Supabase)
// Auth is Clerk; users are mirrored here via the Clerk webhook.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase: pooled connection in DATABASE_URL, direct connection for migrations.
  directUrl = env("DIRECT_URL")
  // pgvector powers the agent's token-efficient recall (memory_chunks.embedding).
  extensions = [vector]
}

model User {
  id        String   @id @default(uuid())
  clerkId   String   @unique
  email     String
  firstName String?
  lastName  String?
  imageUrl  String?
  role      String   @default("member")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entities      Entity[]
  contacts      Contact[]
  apiKeys       ApiKey[]
  conversations Conversation[]
  memoryChunks  MemoryChunk[]

  @@map("users")
}

// A chat with the Scalar agent. A fresh one is created on each page load; long-term
// continuity comes from vector recall over memory_chunks, not from replaying history.
model Conversation {
  id        String    @id @default(uuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "assistant"
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

// Token-efficient memory: embedded snippets of past messages and CRM data the agent
// can recall by similarity instead of stuffing everything into the prompt.
model MemoryChunk {
  id        String                       @id @default(uuid())
  userId    String
  user      User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String // "message" | "entity" | "contact" | "email"
  refId     String? // id of the source record
  content   String                       @db.Text
  embedding Unsupported("vector(1536)")?
  createdAt DateTime                     @default(now())

  @@index([userId])
  @@map("memory_chunks")
}

// Per-user API key for the MCP server / REST API. We store only a SHA-256 hash;
// the plaintext is shown once at creation. `prefix`/`last4` are for display.
model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  hashedKey  String    @unique
  prefix     String
  last4      String
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@map("api_keys")
}

// A business in the CRM. Discovered (e.g. via Tavily), enriched (via Synthoz by
// domain), and operated on by agents. Has many contacts.
model Entity {
  id        String  @id @default(uuid())
  userId    String // owner (the Scalar account)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  domain      String?
  website     String?
  industry    String?
  location    String?
  description String? @db.Text
  size        String?

  status    EntityStatus @default(NEW)
  source    String? // "agent:tavily", "manual", "agent", etc.
  tags      String[]     @default([])
  notes     String?      @db.Text

  // Enrichment payload (Synthoz-shaped JSON the agent can read/extend).
  enrichment Json?

  contacts  Contact[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@map("entities")
}

enum EntityStatus {
  NEW
  ENRICHED
  ARCHIVED
}

// A person/company in the CRM. Agents discover, enrich, and operate on these.
model Contact {
  id        String  @id @default(uuid())
  userId    String // owner (the Scalar account this contact belongs to)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional parent business. A contact is assigned to an entity or stands solo.
  entityId  String?
  entity    Entity? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  // Core
  name      String?
  email     String?
  phone     String?
  company   String?
  title     String?
  website   String?
  linkedin  String?
  location  String?

  // Pipeline
  status    ContactStatus @default(NEW)
  source    String? // how it was found: "discover:domain", "manual", "import", etc.
  tags      String[]      @default([])
  notes     String?

  // Enrichment payload (provider-shaped JSON the agent can read/extend)
  enrichment Json?

  emails    ContactEmail[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
  @@index([entityId])
  @@map("contacts")
}

enum ContactStatus {
  NEW
  ENRICHED
  CONTACTED
  REPLIED
  QUALIFIED
  WON
  LOST
  ARCHIVED
}

// Email exchanged with a contact. Rendered from the connected AgentMail account;
// the agent can save messages here as reusable context.
model ContactEmail {
  id        String  @id @default(uuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  // AgentMail linkage (nullable until a key is connected)
  agentMailMessageId String?
  agentMailThreadId  String?

  direction Emaildirection
  fromAddr  String?
  toAddr    String?
  subject   String?
  body      String?        @db.Text
  // Whether the agent flagged this message as durable context.
  savedAsContext Boolean   @default(false)

  sentAt    DateTime?
  createdAt DateTime @default(now())

  @@index([contactId])
  @@index([agentMailThreadId])
  @@map("contact_emails")
}

enum Emaildirection {
  INBOUND
  OUTBOUND
}
